GOOGLE_CLOUD_PROJECT=myway-ai-501316
BIGQUERY_DATASET=myway_ai
BIGQUERY_LOCATION=asia-south1

# Optional if using a local service-account key.
# In Cloud Run, prefer the service account attached to the service instead.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Optional table overrides. Defaults match the old CSV names.
BIGQUERY_COLLEGES_TABLE=colleges
BIGQUERY_COURSES_TABLE=courses
BIGQUERY_PLACEMENTS_TABLE=placements
BIGQUERY_CUTOFFS_TABLE=cutoffs

# Optional safety controls.
# BIGQUERY_MAX_BYTES_BILLED=1000000000
# BIGQUERY_TABLE_ROW_LIMIT=100000
